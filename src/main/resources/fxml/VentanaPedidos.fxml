<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="850.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    
    <!-- Márgenes generales -->
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Título de la Pantalla -->
    <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Gestión y Seguimiento de Pedidos" />

    <!-- Sección 1: Formulario de Registro -->
    <HBox alignment="CENTER_LEFT" spacing="15.0">
        
        <!-- Un ComboBox para la lista de distribuidores -->
        <VBox spacing="5.0">
            <Label text="Distribuidor:" />
            <ComboBox fx:id="cbDistribuidor" prefWidth="150.0" promptText="Seleccionar..." />
        </VBox>
        
        <!-- Refacción en TextField como lo marcaba la HU -->
        <VBox spacing="5.0">
            <Label text="Refacción:" />
            <TextField fx:id="txtRefaccion" prefWidth="150.0" promptText="Ej. Balatas delanteras" />
        </VBox>
        
        <VBox spacing="5.0">
            <Label text="Cantidad:" />
            <TextField fx:id="txtCantidad" prefWidth="70.0" promptText="Ej. 2" />
        </VBox>
        
        <VBox spacing="5.0">
            <Label text="ID Reparación:" />
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <TextField fx:id="txtIdReparacion" prefWidth="70.0" promptText="Ej. 105" />
                <!-- Checkbox para inventario local -->
                <CheckBox fx:id="chkInventario" text="Para inventario (N/A)" />
            </HBox>
        </VBox>
        
        <Region HBox.hgrow="ALWAYS" /> <!-- Espaciador -->
        
        <VBox alignment="BOTTOM_CENTER">
            <Button fx:id="btnRegistrar" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15 8 15;" text="Registrar Pedido" />
        </VBox>
    </HBox>

    <!-- Sección 2: Barra de Filtros y Búsqueda -->
    <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #ecf0f1; -fx-padding: 10; -fx-background-radius: 5;">
        <Label style="-fx-font-weight: bold;" text="Buscar:" />
        <TextField fx:id="txtBuscar" prefWidth="220.0" promptText="Por distribuidor o pieza..." />
        
        <Label style="-fx-font-weight: bold;" text="Filtrar por estado:" />
        <ComboBox fx:id="cbFiltroEstado" prefWidth="150.0" promptText="Todos" />
    </HBox>

    <!-- Sección 3: Tabla de Seguimiento -->
    <TableView fx:id="tablaPedidos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colIdPedido" prefWidth="60.0" text="ID" />
            <TableColumn fx:id="colDistribuidor" prefWidth="160.0" text="Distribuidor" />
            <TableColumn fx:id="colRefaccion" prefWidth="160.0" text="Refacción" />
            <TableColumn fx:id="colCantidad" prefWidth="70.0" text="Cantidad" />
            <TableColumn fx:id="colIdReparacion" prefWidth="90.0" text="Reparación" />
            <TableColumn fx:id="colEstado" prefWidth="100.0" text="Estado" />
        </columns>
        <placeholder>
            <Label text="No hay pedidos registrados en el sistema." />
        </placeholder>
    </TableView>

    <!-- Sección 4: Acciones de la Tabla -->
    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <Button fx:id="btnCancelarPedido" disable="true" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 12 6 12;" text="Cancelar Pedido" />
        <Button fx:id="btnMarcarEntregado" disable="true" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 12 6 12;" text="Marcar como Entregado" />
    </HBox>

</VBox>
