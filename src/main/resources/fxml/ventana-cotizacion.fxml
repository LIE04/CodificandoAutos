<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="650.0" prefWidth="600.0" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Título de la Ventana -->
    <Label text="Generar Cotización">
        <font>
            <Font name="System Bold" size="20.0" />
        </font>
    </Label>

    <Separator prefWidth="200.0" />

    <!-- SECCIÓN 1: Selección de Cliente y Vehículo -->
    <VBox spacing="10.0">
        <Label text="1. Datos del Cliente y Vehículo" textFill="#555555">
            <font><Font name="System Bold" size="14.0" /></font>
        </Label>
        <HBox spacing="15.0" alignment="CENTER_LEFT">
            <Label text="Cliente:" />
            <ComboBox fx:id="comboClientes" prefWidth="200.0" promptText="Seleccione un cliente..." />
        </HBox>
        <HBox spacing="15.0" alignment="CENTER_LEFT">
            <Label text="Vehículo:" />
            <ComboBox fx:id="comboVehiculos" prefWidth="200.0" promptText="Seleccione un vehículo..." />
        </HBox>
    </VBox>

    <Separator prefWidth="200.0" />

    <!-- SECCIÓN 2: Búsqueda y Agregado de Refacciones -->
    <VBox spacing="10.0">
        <Label text="2. Refacciones" textFill="#555555">
            <font><Font name="System Bold" size="14.0" /></font>
        </Label>
        
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <TextField fx:id="txtBuscarPieza" prefWidth="250.0" promptText="Nombre de la pieza (exacto)" />
            <Button fx:id="btnBuscarPieza" onAction="#accionBuscarRefaccion" text="Buscar" />
        </HBox>

        <ListView fx:id="listRefaccionesEncontradas" prefHeight="100.0" prefWidth="200.0" />

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Label text="Cantidad:" />
            <TextField fx:id="txtCantidadRefaccion" prefWidth="70.0" text="1" />
            <Button fx:id="btnAgregarRefaccion" onAction="#accionAgregarRefaccion" text="Agregar a Cotización" />
        </HBox>
    </VBox>

    <Separator prefWidth="200.0" />

    <!-- SECCIÓN 3: Datos del Servicio y Mano de Obra -->
    <VBox spacing="10.0">
        <Label text="3. Detalles del Servicio" textFill="#555555">
            <font><Font name="System Bold" size="14.0" /></font>
        </Label>
        
        <Label text="Fallas detectadas:" />
        <TextArea fx:id="txtFallas" prefHeight="60.0" wrapText="true" />
        
        <Label text="Descripción de Mano de Obra:" />
        <TextArea fx:id="txtManoObra" prefHeight="60.0" wrapText="true" />
        
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Label text="Costo Mano de Obra: $" />
            <TextField fx:id="txtCostoManoObra" prefWidth="100.0" promptText="0.00" />
            <Button fx:id="btnActualizarServicio" onAction="#accionActualizarServicio" text="Actualizar Datos de Servicio" />
        </HBox>
    </VBox>

    <Separator prefWidth="200.0" />

    <!-- SECCIÓN 4: Totales y Guardado -->
    <VBox spacing="5.0" alignment="CENTER_RIGHT">
        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <Label text="Subtotal:" />
            <Label fx:id="lblSubtotal" text=" 0.00">
                <font><Font name="System Bold" size="12.0" /></font>
            </Label>
        </HBox>
        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <Label text="IVA (16%):" />
            <Label fx:id="lblIva" text=" 0.00">
                <font><Font name="System Bold" size="12.0" /></font>
            </Label>
        </HBox>
        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <Label text="Total:" textFill="#cc0000">
                <font><Font name="System Bold" size="16.0" /></font>
            </Label>
            <Label fx:id="lblTotal" text=" 0.00" textFill="#cc0000">
                <font><Font name="System Bold" size="16.0" /></font>
            </Label>
        </HBox>
        
        <Button fx:id="btnGuardarCotizacion" onAction="#accionGuardarCotizacion" text="Guardar Cotización" prefWidth="200.0" prefHeight="40.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>
    </VBox>

</VBox>