<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" 
      spacing="10" style="-fx-padding: 15px;">
    
    <!-- Título actualizado -->
    <Label text="OmniTaller" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    
    <Button text="Agregar usuario" onAction="#handleAgregarUsuario" 
            style="-fx-min-width: 200px; -fx-min-height: 30px;"/>
    
    <Button text="Listar usuarios" onAction="#handleListarUsuarios" 
            style="-fx-min-width: 200px; -fx-min-height: 30px;"/>
    
    <Button text="Listar grupos" onAction="#handleListarGrupos"
            style="-fx-min-width: 200px; -fx-min-height: 30px;"/>

    <Button text="Registrar pieza" onAction="#handleRegistrarPieza"
            style="-fx-min-width: 200px; -fx-min-height: 30px;"/>

    <Button text="Consultar distribuidores" onAction="#handleConsultarDistribuidores"
            style="-fx-min-width: 200px; -fx-min-height: 30px;"/>

    <Button text="Historial de servicio" onAction="#handleRegistrarServicio"
            style="-fx-min-width: 200px; -fx-min-height: 30px;"/>

    <!-- Nuevo botón para la ventana de pedidos (HU-30) -->
    <Button fx:id="btnPedidos" text="Gestión de Pedidos" onAction="#abrirVentanaPedidos"
            style="-fx-min-width: 200px; -fx-min-height: 30px;"/>

</VBox>