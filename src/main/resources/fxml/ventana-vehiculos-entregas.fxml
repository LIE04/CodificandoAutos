<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" style="-fx-padding: 10px;" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1">

    <!-- Título actualizado -->
    <Label text="Vehículos por entregar" style="-fx-font-size: 14px; -fx-font-weight: bold;" />

    <HBox spacing="10">
        <!-- Textfield alineado con el id de tu controlador -->
        <TextField fx:id="textFieldBusqueda" promptText="Buscar por cliente..." HBox.hgrow="ALWAYS" />
        <!-- El botón llama al método de filtrado que definiste en tu diagrama -->
        <Button onAction="#handleBuscar" style="-fx-min-width: 80px; -fx-min-height: 25px;" text="Buscar" />
    </HBox>

    <Label fx:id="labelMensaje" style="-fx-text-fill: #a33;" wrapText="true" />

    <!-- Tabla actualizada con el fx:id tableVehiculos -->
    <TableView fx:id="tableVehiculos" VBox.vgrow="ALWAYS">
        <columns>
            <!-- Columnas vinculadas exactamente a los fx:id de VistaVehiculosEntrega.java -->
            <TableColumn text="ID" fx:id="idColumn" prefWidth="50.0" />
            <TableColumn text="Cliente" fx:id="nombreColumn" prefWidth="150.0" />
            <TableColumn text="Marca" fx:id="marcaColumn" prefWidth="100.0" />
            <TableColumn text="Modelo" fx:id="modeloColumn" prefWidth="100.0" />
            <TableColumn text="Placas" fx:id="placasColumn" prefWidth="100.0" />
            <TableColumn text="Estatus" fx:id="statusColumn" prefWidth="120.0" />
        </columns>
    </TableView>

    <HBox spacing="10" style="-fx-padding: 10px 0 0 0;">
        <!-- Botón para ir a escaner y ser aprobado despues-->
        <Button onAction="#solicitarEscaner" style="-fx-min-width: 130px; -fx-min-height: 25px;" text="Escaner" />
        <!-- Botón actualizado para coincidir con "Presiona Ver Resumen" del diagrama -->
        <Button onAction="#solicitarResumen" style="-fx-min-width: 130px; -fx-min-height: 25px;" text="Finalizar Entrega" />
        <Button onAction="#handleCerrar" style="-fx-min-width: 80px; -fx-min-height: 25px;" text="Cerrar" />
    </HBox>

</VBox>